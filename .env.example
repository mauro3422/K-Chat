# Kairos Agent - Configuración
# Copiá este archivo como .env y completá tus valores

# --- Servidor ---
HOST=0.0.0.0
PORT=8000

# --- Coordinación LAN ---
# KAIROS_NODE_ID: identificador estable de esta máquina dentro del cluster
KAIROS_NODE_ID=maquina-principal
# KAIROS_NODE_PLATFORM: linux o windows (si se omite, se detecta automáticamente)
# KAIROS_NODE_PLATFORM=windows
# La IP LAN y los pares se descubren automáticamente por multicast.
# Estas variables quedan como overrides opcionales para redes que bloqueen multicast.
# KAIROS_NODE_BASE_URL=http://192.168.1.35:8000
# KAIROS_WEB_BASE_URL: URL canónica que deben ver todas las PCs si querés un único enlace compartido
# Ejemplo para un nodo principal en LAN:
# KAIROS_WEB_BASE_URL=http://192.168.1.40:8000
# KAIROS_PEER_URLS: semillas opcionales separadas por comas o saltos de línea
# Ejemplo para dos PCs:
# KAIROS_PEER_URLS=http://192.168.1.40:8000
KAIROS_PEER_URLS=
KAIROS_LAN_DISCOVERY=true
# KAIROS_LAN_DISCOVERY_GROUP=239.255.42.99
# KAIROS_LAN_DISCOVERY_PORT=42429
# KAIROS_NODE_HEARTBEAT_TTL: tiempo en segundos antes de considerar vencido un nodo
KAIROS_NODE_HEARTBEAT_TTL=15.0
# Secreto HMAC compartido entre nodos. Generá uno; no reutilices claves de APIs.
# python -c "import secrets; print(secrets.token_urlsafe(48))"
KAIROS_LAN_SHARED_SECRET=
# IDs de peers y operadores autorizados, separados por comas.
# El KAIROS_NODE_ID local se agrega automáticamente.
KAIROS_LAN_ALLOWED_NODE_IDS=maquina-secundaria,kairos-ops
# Los clientes operativos firman como este ID; debe figurar en la lista anterior.
# KAIROS_LAN_CLIENT_NODE_ID=kairos-ops
KAIROS_LAN_AUTH_WINDOW_SECONDS=30
KAIROS_LAN_AUTH_NONCE_CAPACITY=4096
KAIROS_LAN_AUTH_MAX_BODY_BYTES=3145728
# Solo habilita requests administrativos sin firma originados en loopback real.
KAIROS_LAN_AUTH_ALLOW_LOOPBACK=false

# --- Modelos ---
# OPENCODE_ZEN_API_KEY: required for LLM API access
OPENCODE_ZEN_API_KEY=sk-tu-api-key-aqui
# OPENCODE_ZEN_BASE_URL: optional, override API base URL
# OPENCODE_ZEN_BASE_URL=https://api.openai.com/v1

# --- Memoria ---
MEMORY_DB_PATH=memory/kairos_curated_memory.db

# --- Búsqueda web ---
# SearXNG incluido en dependencies/ - se auto-arranca con el servidor
SEARXNG_URL=http://127.0.0.1:8080
SEARXNG_AUTO_START=true

# --- Rate limiting ---
# HTTP_RATE_LIMIT: max requests per IP per 60s window (default 60)
# HTTP_RATE_LIMIT=60

# --- Testing ---
# TESTING=true: bypass localhost check on debug endpoints (DO NOT USE IN PRODUCTION)

# --- LLM ---
LLM_PROVIDER=openai
LLM_MODE=go
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# --- Session retention ---
SESSION_MAX_AGE_DAYS=90

# --- Features ---
AUTO_RETRIEVAL_ENABLED=true

# --- Logging ---
KAIROS_LOG_DIR=logs
LOG_LEVEL=INFO

# --- Limits ---
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=5.0
MAX_TOOL_TURNS=100
TOOL_HEARTBEAT_INTERVAL=10.0

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# --- Watchdog (optional) ---
WATCHDOG_INTERVAL=5
WATCHDOG_URL=http://127.0.0.1:8000/health

# --- Environment ---
ENVIRONMENT=production
