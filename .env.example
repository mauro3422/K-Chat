# Kairos Agent - Configuración
# Copiá este archivo como .env y completá tus valores

# --- Modelos ---
OPENCODE_ZEN_API_KEY=sk-tu-api-key-aqui
DEEPSEEK_MODEL=opencode/deepseek-v4-flash-free
MIMO_MODEL=opencode/mimo-v2.5-free

# --- Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# --- Memoria ---
MEMORY_DB_PATH=memory/kairos_memory.db

# --- Opcional ---
WEB_SEARCH_ENABLED=true
CRON_ENABLED=true
